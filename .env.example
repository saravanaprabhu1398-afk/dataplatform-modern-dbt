# DP Flow — Environment Configuration
# Copy this file to .env and fill in values before starting.
# Never commit .env to version control.

# ── Authentication (REQUIRED — change all defaults before deploying) ──────────
DATAPLATFORM_USERNAME=admin
DATAPLATFORM_PASSWORD=changeme
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
DATAPLATFORM_SESSION_SECRET=changeme

# ── Server ────────────────────────────────────────────────────────────────────
DATAPLATFORM_HOST=0.0.0.0
DATAPLATFORM_PORT=8000

# ── Storage paths ─────────────────────────────────────────────────────────────
# Absolute paths are recommended in deployed environments.
DATABASE_PATH=data/platform.db
DATA_DIR=data
PIPELINES_PATH=pipelines
GIT_CLONES_PATH=data/git-clones

# ── Execution ─────────────────────────────────────────────────────────────────
# Maximum number of pipeline runs that can execute concurrently.
PIPELINE_WORKERS=4

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_JSON=false
LOG_FILE=logs/pipeline.log

# ── Optional connector secrets (only fill what you use) ──────────────────────
# PostgreSQL
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=mydb
# POSTGRES_USER=user
# POSTGRES_PASSWORD=
# POSTGRES_URL=postgresql://user:password@localhost:5432/mydb

# Snowflake
# SNOWFLAKE_ACCOUNT=
# SNOWFLAKE_USER=
# SNOWFLAKE_PASSWORD=
# SNOWFLAKE_DATABASE=
# SNOWFLAKE_WAREHOUSE=

# BigQuery
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json

# Kafka
# KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# MySQL
# MYSQL_HOST=localhost
# MYSQL_PORT=3306
# MYSQL_DB=mydb
# MYSQL_USER=user
# MYSQL_PASSWORD=

# Email alerts
# EMAIL_SENDER=
# EMAIL_PASSWORD=
# EMAIL_SMTP_HOST=smtp.gmail.com
# EMAIL_SMTP_PORT=587
